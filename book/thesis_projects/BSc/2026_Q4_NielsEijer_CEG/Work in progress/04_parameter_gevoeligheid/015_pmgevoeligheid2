   "source": [
    "run_files = sorted(parameter_results_dir.glob(\"*_lobith_daily.csv\"))\n",
    "\n",
    "score_rows = []\n",
    "\n",
    "for file_path in run_files:\n",
    "    model_output = pd.read_csv(file_path)\n",
    "    model_output[\"date\"] = pd.to_datetime(model_output[\"date\"])\n",
    "\n",
    "    comparison = pd.merge(\n",
    "        grdc_calibration,\n",
    "        model_output,\n",
    "        on=\"date\",\n",
    "        how=\"inner\"\n",
    "    )\n",
    "\n",
    "    run_scores = scores(comparison)\n",
    "    run_scores[\"run_name\"] = file_path.stem.replace(\"_lobith_daily\", \"\")\n",
    "    run_scores[\"file\"] = file_path.name\n",
    "\n",
    "    score_rows.append(run_scores)\n",
    "\n",
    "scores_all = pd.DataFrame(score_rows)\n",
    "\n",
    "scores_all.round(2)"
   ]
